# GPU VM -> session assignment for the parallel AU batch (one session per VM).
# Copy to vm_assignments.env (gitignored) and fill in your real VM IPs.
# Format:  <VM_PUBLIC_IP>  <SESSION_ID>  <VM_LABEL>
<VM_PUBLIC_IP_1>  <SESSION_ID_1>  vm-au-1
<VM_PUBLIC_IP_2>  <SESSION_ID_2>  vm-au-2
<VM_PUBLIC_IP_3>  <SESSION_ID_3>  vm-au-3
<VM_PUBLIC_IP_4>  <SESSION_ID_4>  vm-au-4
